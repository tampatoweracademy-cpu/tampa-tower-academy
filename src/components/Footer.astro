---
const year = new Date().getFullYear();
const enrollUrl = 'https://forms.gle/GSf12Znbd63fsDfk7';
---

<footer class="site-footer">
  <div class="wrap cols">
    <div>
      <div class="brand">
        <img src="/images/logo.png" alt="" width="52" height="52" />
        <span>Tampa Tower Academy</span>
      </div>
      <p class="tag">A Bible-based K–8 academy in Tampa, Florida.</p>
    </div>

    <nav aria-label="Footer">
      <h2>Explore</h2>
      <ul>
        <li><a href="/about">About</a></li>
        <li><a href="/curriculum">Curriculum</a></li>
        <li><a href="/programs">Programs</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href={enrollUrl} target="_blank" rel="noopener">Enroll now</a></li>
      </ul>
    </nav>

    <div>
      <h2>Get in touch</h2>
      <ul class="contact">
        <li><a href="mailto:support@tampatower.org">support@tampatower.org</a></li>
        <li><a href="tel:+18134060306">(813) 406-0306</a></li>
        <li>Tampa, Florida</li>
      </ul>
    </div>
  </div>

  <div class="wrap sub">
    <p>© {year} Tampa Tower Academy. All rights reserved.</p>
    <p>100% tuition-free · Approved provider for Step Up For Students (EMA Marketplace)</p>
  </div>
</footer>

<style>
  .site-footer { background: var(--navy-deep); color: rgba(247, 245, 239, 0.8); padding-block: 3rem 1.5rem; }
  .cols { display: grid; gap: 2rem; }
  @media (min-width: 46rem) { .cols { grid-template-columns: 1.4fr 1fr 1fr; } }
  .brand { display: flex; align-items: center; gap: 0.65rem; }
  .brand img { border-radius: 6px; }
  .brand span { font-family: var(--font-serif); font-size: 1.2rem; color: var(--white); }
  .tag { margin-top: 0.75rem; max-width: 28ch; }
  .site-footer h2 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--gold-light); font-family: var(--font-sans); margin-bottom: 0.75rem; }
  .site-footer ul { list-style: none; margin: 0; padding: 0; }
  .site-footer li { margin-bottom: 0.5rem; }
  .site-footer a { color: rgba(247, 245, 239, 0.85); text-decoration: none; }
  .site-footer a:hover { color: var(--gold-light); }
  .sub {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.85rem;
  }
  .sub p { margin: 0; }
</style>
